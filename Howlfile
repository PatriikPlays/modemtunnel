Options:Default "trace"

Tasks:clean()

Tasks:minify "minify" {
	input = "build/modemtunnel.lua",
	output = "build/modemtunnel.min.lua",
}

Tasks:require "main" {
	include = "src/*.lua",
	startup = "src/modemtunnel.lua",
	output = "build/modemtunnel.lua",
	rename = function(file)
		-- remove src prefix, there has to be a better way to do this but i dont know of it
		local name = file.name:gsub("^src.", "")
		return name
	end,
	modify = function(file)
		local contents = file.contents
		-- remove shebang line if it exists
		contents = contents:gsub("^#!.-\n", "")
		return contents
	end,
}

Tasks:Task "build" { "clean", "minify" } :Description "Main build task"

Tasks:Default "main"
